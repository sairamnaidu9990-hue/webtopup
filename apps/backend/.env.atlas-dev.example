HOST=127.0.0.1
PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb+srv://webtopup_dev_user:replace-with-password@replace-with-cluster-url/webtopup-dev?retryWrites=true&w=majority&appName=webtopup-dev
JWT_SECRET=local-dev-secret-change-me
BANGJEFF_API_KEY=replace-with-dev-bangjeff-key
BANGJEFF_REGION=ID
BANGJEFF_BASE_URL=https://distribution-api.bangjeff.com
BANGJEFF_TIMEZONE=Asia/Jakarta
TOKOPAY_MERCHANT_ID=replace-with-dev-tokopay-merchant-id
TOKOPAY_SECRET=replace-with-dev-tokopay-secret
TOKOPAY_API_BASE=https://api.tokopay.id
TOKOPAY_EXPIRED_MINUTES=1440
FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://127.0.0.1:4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
TRUST_PROXY=1
ALLOW_LOCAL_WEBHOOKS=true
JSON_BODY_LIMIT=100kb
URLENCODED_BODY_LIMIT=100kb
ADMIN_TOKEN_EXPIRES_IN=7d
DEFAULT_VARIANT_MARKUP=0
