HOST=127.0.0.1
PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/webtopup
JWT_SECRET=replace-with-strong-secret
BANGJEFF_API_KEY=replace-with-your-bangjeff-api-key
BANGJEFF_REGION=ID
BANGJEFF_BASE_URL=https://distribution-api.bangjeff.com
BANGJEFF_TIMEZONE=Asia/Jakarta
TOKOPAY_MERCHANT_ID=replace-with-your-tokopay-merchant-id
TOKOPAY_SECRET=replace-with-your-tokopay-secret
TOKOPAY_API_BASE=https://api.tokopay.id
TOKOPAY_EXPIRED_MINUTES=1440
RECAPTCHA_SECRET_KEY=
FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://127.0.0.1:4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
TRUST_PROXY=1
ALLOW_LOCAL_WEBHOOKS=true
JSON_BODY_LIMIT=100kb
URLENCODED_BODY_LIMIT=100kb
ADMIN_TOKEN_EXPIRES_IN=7d
DEFAULT_VARIANT_MARKUP=0
